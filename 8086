#include <stdio.h>
#include <string.h>

int main() {
    char line[50];
    char result[10], arg1[10], arg2[10], op;

    printf("Enter Three Address Code statements (type 'exit' to stop):\n");

    while (1) {
        printf("\nTAC: ");
        scanf(" %[^\n]", line);   // Read full line including spaces

        if (strcmp(line, "exit") == 0)
            break;

        // Try parsing: x = y op z
        if (sscanf(line, "%s = %s %c %s", result, arg1, &op, arg2) == 4) {

            printf("\n8086 Assembly Code:\n");

            printf("MOV AX, %s\n", arg1);

            if (op == '+')
                printf("ADD AX, %s\n", arg2);
            else if (op == '-')
                printf("SUB AX, %s\n", arg2);
            else {
                printf("Unsupported operator!\n");
                continue;
            }

            printf("MOV %s, AX\n", result);
        }

        // Try parsing: x = y
        else if (sscanf(line, "%s = %s", result, arg1) == 2) {

            printf("\n8086 Assembly Code:\n");

            printf("MOV AX, %s\n", arg1);
            printf("MOV %s, AX\n", result);
        }

        else {
            printf("Invalid TAC format!\n");
        }
    }

    return 0;
}